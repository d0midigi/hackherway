            --bg: #0a0a0a;
            --bg-elevated: #111111;
            --bg-card: #161616;
            --bg-hover: #1c1c1c;
            --bg-code: #1a1a1a;
            --border: #222222;
            --border-hover: #2a2a2a;
            --text-primary: #f0f0f0;
            --text-secondary: #888888;
            --text-muted: #555555;
            --pink: #fe0942;
            --pink-soft: #ff1a5c;
            --pink-muted: #cc0033;
            --pink-glow: rgba(254, 9, 66, 0.15);
