        .nav-brand .brand-dot {
            width: 8px; height: 8px; background: var(--pink); border-radius: 50%;
            box-shadow: 0 0 12px var(--pink-glow);
        }
        .nav-links { display: flex; gap: 4px; }
        .nav-link {
            padding: 6px 14px; border-radius: var(--radius); font-size: 13px;
            font-weight: 500; color: var(--text-secondary); text-decoration: none;
            transition: var(--transition); cursor: pointer;
        }
        .nav-link:hover, .nav-link.active {
            color: var(--text-primary); background: var(--bg-hover);
        }
        .nav-link.active { color: var(--pink); }
        .container {
            max-width: 1400px; margin: 0 auto;
