        .sidebar-item a:hover {
            color: var(--text-primary); background: var(--bg-hover);
        }
        .sidebar-item a.active {
            color: var(--pink); background: var(--pink-glow); font-weight: 500;
        }
        .sidebar-item a.active::before {
            content: ''; display: inline-block; width: 3px; height: 3px;
            background: var(--pink); border-radius: 50%; margin-right: 8px; vertical-align: middle;
        }
