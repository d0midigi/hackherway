            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }
        .card:hover::before { opacity: 1; }
        .card-tag {
            display: inline-block; font-size: 10px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1px; color: var(--pink);
            background: var(--pink-glow); padding: 3px 8px; border-radius: 3px; margin-bottom: 12px;
